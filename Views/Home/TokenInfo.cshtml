@{
    ViewData["Title"] = "Отчет по токенам OIDC";
}
<div class="container mt-4">
    <h2 class="mb-4">Пользователь авторизован</h2>

    <div class="mb-4">
        <p><strong>Имя:</strong> @ViewBag.UserName</p>
        <p><strong>Email:</strong> @ViewBag.UserEmail</p>
        <p><strong>Token Type:</strong> @ViewBag.TokenType</p>
        <p><strong>Scope:</strong> [@ViewBag.Scope]</p>
        <p><strong>Access Token истекает:</strong> @ViewBag.ExpiresAt</p>
        <p><strong>Expires In:</strong> <span id="countdown">@ViewBag.ExpiresIn</span></p>
        <p><strong>Последнее обновление токенов:</strong> @ViewBag.LastRefreshTime</p>
    </div>

    <hr />

    <h4 class="mt-4">Access Token</h4>
    <div class="alert alert-secondary" style="word-wrap: break-word; font-family: monospace; font-size: 0.85em;">
        @ViewBag.AccessToken
    </div>

    <h4 class="mt-4">ID Token</h4>
    <div class="alert alert-secondary" style="word-wrap: break-word; font-family: monospace; font-size: 0.85em;">
        @ViewBag.IdToken
    </div>

    <h4 class="mt-4">Refresh Token</h4>
    <div class="alert alert-secondary" style="word-wrap: break-word; font-family: monospace; font-size: 0.85em;">
        @ViewBag.RefreshToken
    </div>

    <hr />

    <h4 class="mt-4">ID Token Payload</h4>
    <pre class="bg-light p-3 border rounded" style="white-space: pre-wrap; font-size: 0.85em;">@ViewBag.IdTokenPayload</pre>

    <h4 class="mt-4">Access Token Payload</h4>
    <pre class="bg-light p-3 border rounded" style="white-space: pre-wrap; font-size: 0.85em;">@ViewBag.AccessTokenPayload</pre>

    <hr />

    <h4 class="mt-4">Данные профиля (UserInfo Endpoint)</h4>
    <form asp-controller="Home" asp-action="TokenInfo" method="get" class="mb-3">
        <input type="hidden" name="fetchUserInfo" value="true" />
        <button type="submit" class="btn btn-outline-primary">
            Запросить UserInfo
        </button>
    </form>

    <p><strong>Время получения данных:</strong> @ViewBag.FetchTime</p>
    <pre class="bg-light p-3 border rounded" style="white-space: pre-wrap; font-size: 0.85em;">@ViewBag.UserInfoJson</pre>

    <div class="mt-4 mb-5">
        <form id="refresh-form" asp-controller="Home" asp-action="RefreshTokens" method="post" class="d-inline">
            <button type="submit" class="btn btn-outline-success">
                Обновить токены вручную
            </button>
        </form>

        <form asp-controller="Home" asp-action="Logout" method="post" class="d-inline ml-2">
            <button type="submit" class="btn btn-outline-dark">Выйти</button>
        </form>
    </div>
</div>

<script>
    // Берём время истечения токена которое сервер передал в страницу
    const expiresAt = new Date("@ViewBag.ExpiresAtJs");
    const countdown = document.getElementById("countdown");

    function updateCountdown() {
        const now = new Date();
        const secondsLeft = Math.max(0, Math.floor((expiresAt - now) / 1000));

        if (secondsLeft === 0) {
            countdown.textContent = "Токен истёк";
            countdown.style.color = "red";
            return;
        }

        const minutes = Math.floor(secondsLeft / 60);
        const seconds = secondsLeft % 60;
        countdown.textContent = `${minutes}м ${seconds}с`;

        // Красим в жёлтый когда меньше 5 минут
        if (secondsLeft <= 300) {
            countdown.style.color = "orange";
        }

        // если осталось ровно 300 секунд (5 минут), отправляем форму
        if (secondsLeft === 300) {
            console.log("Осталось 5 минут. Выполняю автоматическое обновление токенов...");
            document.getElementById("refresh-form").submit();
        }
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);
</script>